#!/usr/bin/env bash

set -euo pipefail

qsIpc=(qs ipc)

function choose::callWs() {
    "${qsIpc[@]}" call windowPicker chooseInWorkspace "$1"
}

function choose::callAny() {
    "${qsIpc[@]}" call windowPicker chooseAny
}

function wait::result() {
    result=$("${qsIpc[@]}" wait windowPicker picked)
    if [ -n "$result" ]; then
        echo "$result"
    else
        >&2 echo "No result returned"
        return 1
    fi
}

if [ -n "${1:-}" ]; then
    choose::callWs "$1"
else
    choose::callAny
fi

wait::result

